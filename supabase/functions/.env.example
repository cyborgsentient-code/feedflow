# Supabase Edge Function secrets — set via: supabase secrets set KEY=value

# Instagram OAuth App (from developers.facebook.com)
INSTAGRAM_APP_ID=your_instagram_app_id
INSTAGRAM_APP_SECRET=your_instagram_app_secret

# Must match exactly what's registered in Instagram app dashboard
# Format: https://<project>.supabase.co/functions/v1/instagram-auth
INSTAGRAM_REDIRECT_URI=your_instagram_redirect_uri

# Deep link scheme — must match app.json scheme
APP_SCHEME=feedflow://

# Demo mode: set to "true" to run 3–5 deterministic actions per user per invocation
# Also triggerable via ?demo=true query param on the automation-loop function
DEMO_MODE=false
